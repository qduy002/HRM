PORT=5001
CLIENT_URL=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hrm
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
ACCESS_TOKEN_SECRET=change-me-in-production-please

# Super Admin seed — dùng cho `npm run seed:super-admin`
SUPER_ADMIN_EMAIL=admin@hrm.local
SUPER_ADMIN_PASSWORD=Admin@123456
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# Cloudflare R2 (S3-compatible object storage — dùng presigned URL)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hrm-uploads
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
